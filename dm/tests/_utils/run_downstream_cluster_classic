#!/usr/bin/env bash
# Start a classic (single-PD + single-TiKV + single-TiDB) downstream cluster.
# parameter 1: work directory
set -eux
CUR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
source "$CUR/env_variables"
WORK_DIR=$1

# Classic cluster needs these — on next-gen they come from env_variables.
export PD_PEER_ADDR=${PD_PEER_ADDR:-"127.0.0.1:2380"}
export PD_ADDR=${PD_ADDR:-"127.0.0.1:2379"}
export TIKV_ADDR=${TIKV_ADDR:-"127.0.0.1:2016"}
export TIKV_STATUS_ADDR=${TIKV_STATUS_ADDR:-"127.0.0.1:2018"}

start_pd() {
	echo "Starting PD..."

	cat >"$WORK_DIR/pd.toml" <<EOF
[replication]
# The number of replicas for each region.
max-replicas = 1
EOF

	bin/pd-server --version
	mkdir -p "$WORK_DIR/pd"
	bin/pd-server \
		--client-urls "http://$PD_ADDR" \
		--peer-urls "http://$PD_PEER_ADDR" \
		--log-file "$WORK_DIR/pd.log" \
		--config "$WORK_DIR/pd.toml" \
		--data-dir "$WORK_DIR/pd" &
	sleep 5
	i=0
	while true; do
		response=$(curl -s -o /dev/null -w "%{http_code}" "http://$PD_ADDR/pd/api/v1/version" || echo "")
		echo "curl response: $response"
		if [ "$response" -eq 200 ]; then
			echo 'Start PD success'
			break
		fi
		i=$((i + 1))
		if [ "$i" -gt 20 ]; then
			echo 'Failed to start PD'
			exit 1
		fi
		echo 'Waiting for PD ready...'
		sleep 3
	done
}

start_tikv() {
	echo "Starting TiKV..."
	mkdir -p "$WORK_DIR/tikv"
	bin/tikv-server --version
	bin/tikv-server \
		--pd "$PD_ADDR" \
		-A "$TIKV_ADDR" \
		--status-addr "$TIKV_STATUS_ADDR" \
		--log-file "$WORK_DIR/tikv.log" \
		--log-level info \
		-s "$WORK_DIR/tikv" &
	sleep 5
	i=0
	while true; do
		response=$(curl -s "http://$PD_ADDR/pd/api/v1/cluster/status" || echo "")

		if [ -z "$response" ]; then
			echo "Failed to connect to PD server"
		else
			echo "PD response: $response"
			if echo "$response" | grep -q '"is_initialized": true'; then
				echo "TiKV cluster initialized successfully"
				break
			fi
		fi

		i=$((i + 1))
		if [ "$i" -gt 20 ]; then
			echo 'Failed to initialize TiKV cluster after 20 attempts'
			exit 1
		fi

		echo 'Waiting for TiKV ready...'
		sleep 5
	done
}

start_pd
start_tikv

# PD_ADDR is already exported above; run_tidb_server derives --store tikv
# from it automatically.
CUR_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
"$CUR_DIR/run_tidb_server" 4000 123456
