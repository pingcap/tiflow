#!/usr/bin/env bash
# Dispatcher for starting a TLS-enabled downstream TiDB cluster used by the
# openapi test_tls case.
#
# NEXT_GEN=1 → restart only the user TiDB with TLS, keeping PD/TiKV/
#              tikv-worker/SYSTEM TiDB alive (test_tls killall-9 on those is
#              a classic-only teardown pattern that would corrupt the
#              DFS-backed keyspace).
# otherwise → full classic PD + TiKV + TiDB bring-up with TLS across all
#              components, matching the original behavior.
set -eu

CUR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

if [ "${NEXT_GEN:-}" = "1" ]; then
	"$CUR/run_downstream_cluster_with_tls_nextgen" "$@"
else
	"$CUR/run_downstream_cluster_with_tls_classic" "$@"
fi
