#!/usr/bin/env bash
# Dispatcher for starting a downstream TiDB cluster.
#
# When NEXT_GEN=1, delegate to run_downstream_cluster_nextgen which spins up
# the full next-gen architecture (MinIO + PD + TiKV + tikv-worker + SYSTEM
# TiDB + user keyspace TiDB). Otherwise, delegate to
# run_downstream_cluster_classic which starts the simple classic cluster
# (single PD + TiKV + TiDB).
#
# parameter 1: work directory
set -eu

CUR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

if [ "${NEXT_GEN:-}" = "1" ]; then
	"$CUR/run_downstream_cluster_nextgen" "$@"
else
	"$CUR/run_downstream_cluster_classic" "$@"
fi
